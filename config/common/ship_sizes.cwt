#ship_class = {
#	name = key #i dunno how to do this, but a shipclass entry is a must.
#}

enums = {
	complex_enum[ship_class] = {
		path = "game/common/ship_sizes"
		name = {
			class = enum_name
		}
	}
	complex_enum[section_slot] = {
		path = "game/common/ship_sizes"
		name = {
			section_slots = {
				enum_name = {
				}
			}
		}
	}
}

