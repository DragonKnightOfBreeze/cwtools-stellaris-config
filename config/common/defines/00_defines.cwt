    NCombat = {
        ### When ships are attacking they will try to stay at max range and orbit their target.
        ### If the ship is closer than max range this value determines how fast it will "back off" in order to get to max range.
        ### 0.0 means that the ship will not back off and orbit with whatever radius it already has
        ### 1.0 means that the ship will prioritize orbit velocity the same as "back-off"-velocity. i.e a 45 degree angle
        COMBAT_BACK_OFF_RATE = float
        ### Desired combat ranges should be slightly less than the actual range of a weapon.
        COMBAT_DESIRED_RANGE_MULT = float
        ### If a target is hitting us with impunity, we will multiply our desired range by this to see if we think we should charge them
        COMBAT_CHARGE_DISTANCE_COEFFICIENT = float

        ### Used to smooth rotation rate of ships. equation is "y = x * ( min ( 1.0 x / SHIP_SMOOTH_ROTATION_THRESHOLD ) )" where x is the wanted delta rotation this tick and y the resulting delta rotation
        SHIP_SMOOTH_ROTATION_THRESHOLD = float

        ### Added to size of fleets when calculating force disparity
        FORCE_DISPARITY_BASE = int
        ### Max multiplier on force disparity
        FORCE_DISPARITY_MAX_EFFECT = float

        ### multiplier applied to the score of the current target of ships and components that focus on a single target
        ### should be higher than 1
        SHIP_CURRENT_TARGET_MULTIPLIER = float(1..inf]
        ### multiplier applied to the score of recent targets of ships and components that spread their fire among enemies
        ### should be between 0 and 1
        SHIP_RECENT_TARGET_PENALIZER = float[0..1]
        ### number of recent targets to remember and try to avoid when spreading fire
        NUMBER_OF_TARGETS_TO_REMEMBER = float

        ### The higher this is, the more random ship targeting will be. Only affects ship's main target
        RANDOM_TARGETING_WEIGHT = float

        ### Chance that admiral dies when their ship gets blown up
        ADMIRAL_DEATH_CHANCE = float

        ### The higher this weight is, the more likely smaller, more fragile ships are to be targeted first
        COMBAT_SHIP_TARGETING_SIZE_MULT = float
        COMBAT_SHIP_TARGETING_SIZE_MAX = int
        ### This weight is needed to ensure high-tracking ships target high-evasion ships
        COMBAT_SHIP_TARGETING_TRACKING_MULT = float
        ### The higher this is, the less likely ships are to target enemy ships with high chance to evade their shots
        COMBAT_SHIP_EVASION_TARGETING_WEIGHT = float
        ### The health threshold at which the low health targeting weight is applied
        COMBAT_SHIP_LOW_HEALTH_THRESHOLD = float
        COMBAT_SHIP_LOW_HEALTH_TARGETING_WEIGHT = float
        ### The higher this is, the less likely ships will be to fire on distant targets
        COMBAT_SHIP_DISTANCE_TARGETING_WEIGHT = float
        ### Target weight can't be multiplied by less than this due to distance
        COMBAT_SHIP_DISTANCE_TARGETING_WEIGHT_MIN = float
        ### The lower this is, the less likely ships are to target unarmed enemies over armed ones
        COMBAT_SHIP_UNARMED_TARGETING_WEIGHT = float
        ### The lower this is, the less likely ships are to target Starbases over military ships & defense platforms
        COMBAT_SHIP_STARBASE_TARGETING_WEIGHT = float
        ### Minimum size of ships that should try to avoid firing on highly evasive targets
        COMBAT_SHIP_EVASION_AVOID_MIN_SHIP_SIZE = int
        ### Above this level of evasion, try to find a less evasive target
        COMBAT_SHIP_EVASION_AVOID_THRESHOLD = float

        ### Range to engage in combat with other ships is <fleets max attack range> * COMBAT_DETECT_RANGE_MULT
        COMBAT_DETECT_RANGE_MULT = float
        COMBAT_DETECT_RANGE_MIN = int
        COMBAT_AREA_MIN_ATTACK_RADIUS = float
        ### x% risk of ship becoming forever lost when jumping.
        COMBAT_EMERGENCY_FTL_LOST_RISK = float
        ### x% chance of ship taking damage in emergency ftl jump
        COMBAT_EMERGENCY_FTL_DAMAGE_RISK = float
        ### x% of damage that emergency ftl can potentially cause
        COMBAT_EMERGENCY_FTL_DAMAGE_AMOUNT = float
        ### how many days a fleet should be in combat until they can emergency ftl
        COMBAT_BASE_DAYS_UNTIL_EMERGENCY_FTL = float

        ### if the missile is closer to the target than MISSILE_HIGH_CONTROL_DISTANCE it will turn sharply
        MISSILE_HIGH_CONTROL_DISTANCE = float
        ### how long the missile will interpolate between "smooth controls" and "full control"
        MISSILE_HIGH_CONTROL_INTERPOLATION_RANGE = float
        ### base rotation rate of missiles in radians per tick
        MISSILE_BASE_ROTATION_SPEED = float
        ### How likely a missile is to find a new target in range the first time its target is lost
        MISSILE_RETARGET_CHANCE_START = int
        ### How much the chance for a missile to find a new target is reduced each retargeting after the first
        MISSILE_RETARGET_CHANCE_REDUCTION = int

        ### Chance each time a ship takes damage that it disengages, scales with damage received (X = chance at SHIP_DISENGAGE_HEALTH_THRESHOLD of health damage)
        SHIP_DISENGAGE_BASE_CHANCE = float
        SHIP_DISENGAGE_MAX_CHANCE = float
        ### Health must be below this before damage taken for a ship to disengage
        SHIP_DISENGAGE_HEALTH_THRESHOLD = float
        SHIP_DISENGAGE_FRIENDLY_TERRITORY_MULT = float
    }
    NPop = {
        ### Base political power
        BASE_POLITICAL_POWER = float
        MIN_POLITICAL_POWER_POSITIVE_STABILITY_IMPACT = float
        MAX_POLITICAL_POWER_POSITIVE_STABILITY_IMPACT = int
        MIN_POLITICAL_POWER_NEGATIVE_STABILITY_IMPACT = float
        MAX_POLITICAL_POWER_NEGATIVE_STABILITY_IMPACT = int

        ### Base growth rate of pops
        BASE_POP_GROWTH = float
        ### Logistic Pop Growth Constant r
        LOGISTIC_POP_GROWTH_R = float
        ### Logistic Pop Growth won't lower growth to less than this percent.
        LOGISTIC_POP_GROWTH_FLOOR = float
        ### Treat small colonies as having this many pops to avoid the very bottom of the curve
        LOGISTIC_POP_GROWTH_MIN_POPS = int
        ### Ignore penalties to Pop Growth if the current number of pops of the species are below this percent of the carrying capacity
        LOGISTIC_POP_GROWTH_LOWER_THRESHOLD = float
        ### Logistic Carrying Capacity Cap (so modders have access to this value in case they make a planet with infinite districts or something like that)
        MAX_CARRYING_CAPACITY = int
        ### At this ratio of new to old colonies, no further scaling of migration
        MAX_NEW_COLONIES_SCALE = int
        ### Default amount by which a pop group changes size in forced resettlement, effects like create_pop etc.
        POP_BULK_UNIT_SIZE = int
        ### Pop groups size for merging small groups together, that is 2x99 groups can become 1x198 group if partial key of species and category allows it.
        POP_GROUP_COLLAPSING_THRESHOLD = int
        ### Outliner will show the orange briefcase if there are this many or more civilians + unemployed
        POP_OUTLINER_CIVILIAN_WARNING = int
        ### Number of pops at which planet colonization is completed.
        COLONY_POPS_REQUIRED = int
        ### Damage to colonization pops from bombarding fleet. Multiplied by bombardment stance planet_damage
        COLONY_BOMBARDMENT_DAMAGE = int

        ### At this amount of overcrowding (required housing / actual housing), growth stops entirely
        OVERCROWDING_NO_GROWTH_THRESHOLD = float
        ### At this amount of overcrowding (required housing / actual housing), pops start declining
        OVERCROWDING_DECLINE_THRESHOLD = float
        ### Planet needs this amount of overcrowding (required housing - actual housing) for OVERCROWDING_NO_GROWTH_THRESHOLD to kick in
        OVERCROWDING_ABSOLUTE_THRESHOLD_FOR_NO_GROWTH = int

        ### At this amount of overcrowding (required housing / actual housing), robot and machine assemebly stops entirely
        OVERCROWDING_NO_ASSEMBLY_THRESHOLD = float
        ### At this amount of overcrowding (required housing / actual housing), robot and machine pops start declining
        OVERCROWDING_MACHINE_DECLINE_THRESHOLD = float
        ### Planet needs this amount of overcrowding (required housing - actual housing) for OVERCROWDING_NO_ASSEMBLY_THRESHOLD to kick in
        OVERCROWDING_MACHINE_ABSOLUTE_THRESHOLD_FOR_NO_GROWTH = int
        ### amount of assembly that will be returned when reaching the overcrowding threshold (ie value used for "no assembly")
        MACHINE_ASSEMBLY_WHEN_OVERCROWDED = int

        ### Base pop amount that can auto-migrate from a planet per month
        RESETTLE_UNEMPLOYED_BASE_RATE = int
        ### Influence surcharge for manually resettling the last pop from a colony
        RESETTLE_DESTROY_COLONY_COST = int
        ### Multiplier applied to score of auto-migration targets in other empires
        RESETTLE_ABROAD_MULTIPLIER = float

        ### If habitability is under this, apply exponentially increasing penalties to assembly weight
        ASSEMBLY_WEIGHT_HABITABILITY_THRESHOLD = float
        ### If habitability is under current threshold, apply increasing penalties to assembly weight
        ASSEMBLY_WEIGHT_LOW_HABITABILITY_PENALTY = int
        ### Pops have increased weight for assembling on their homeworld
        ASSEMBLY_WEIGHT_HOMEWORLD_MULT = int
        ### Extra weight per trait point for assembled pops
        ASSEMBLY_WEIGHT_TRAIT_MULT = int
        ### Extra weight for a country assembling its own species if it can
        ASSEMBLY_WEIGHT_FOUNDER_SPECIES_MULT = float
        ### How much does species' total predicted growth matter for assembly weight
        ASSEMBLY_WEIGHT_GROWTH_RATE_MULT = float

        ### Pops above this stratum rank will not be enslaved from civics, etc
        POP_ENSLAVE_MAX_RANK = int

        ### Base decline rate of pops
        BASE_POP_DECLINE = int

        ### Base assembly rate of pops
        BASE_POP_ASSEMBLY = int

        ### A job must have this much higher weight in order for a pop to switch to it from their current job
        DEFAULT_CHANGE_JOB_THRESHOLD = float

        ### Workforce factor is raised to this power when calculating job weights, amplifying differences between pops. 1 = linear, 3 = industrious (+0.15) miner gets 1.15^3 = 1.52x weight.
        POP_JOB_WORKFORCE_WEIGHT_POWER = int

        ### Weight multiplier applied to a job marked as the planet favorite, ensuring it fills before other jobs of the same stratum rank.
        FAVORITE_JOB_WEIGHT_MULT = float

        ### Below this happiness, show bar as red
        LOW_HAPPINESS = float
        ### Above this happiness, show bar as green
        HIGH_HAPPINESS = float

        ### Which category rank should pops from assembly be spawned in
        NEWLY_ASSEMBLED_POP_TARGET_RANK = int

        ### Base value of pop production
        BASE_PRODUCTION = float
        ### Base value of pop happiness
        BASE_HAPPINESS = float

        ### How long the recently conquered modifier stays on pops.
        RECENTLY_CONQUERED_DAYS = int
    }
