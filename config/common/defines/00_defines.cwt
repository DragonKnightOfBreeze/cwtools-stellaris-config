        ARMY_MILITARY_POWER_EXPONENT = float
        ARMY_MILITARY_POWER_DAMAGE_MULT = int
        ARMY_MILITARY_POWER_MORALE_DAMAGE_MULT = float
        ARMY_MILITARY_POWER_HEALTH_MULT = int
        ARMY_MILITARY_POWER_MORALE_MULT = float
        ARMY_MILITARY_POWER_NO_MORALE_FACTOR = int

