        PEACE_STATUS_QUO_FACTOR = int
        PEACE_HIGH_WE_STATUS_QUO_FACTOR = int
        ### Extra AI acceptance for status quo when they are in a stale war where nothing can happen
        PEACE_STALE_WAR_STATUS_QUO_FACTOR = int
        ### Number of times the AI has to fail at finding any military objectives to trigger the stale war
        STALE_WAR_TIMER = int
        PEACE_DEMAND_SURRENDER_FACTOR = int
        ### For every system
        PEACE_DEFENDING_CLAIM_SYSTEM_FACTOR = int
        ### For systems with upgraded starbases
        PEACE_DEFENDING_CLAIM_STARBASE_FACTOR = int
        ### For systems with colonies
