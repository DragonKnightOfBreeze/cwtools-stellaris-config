    NShip = {
        ### Transport fleets on aggressive stance want to have combat strength of enemy ground troops x this to invade a world
        AGGRESSIVE_STANCE_INVASION_ODDS_MULT = float
        ### Fleets that are less than our military power x this will be ignored by aggressive fleets that are bombarding
        AGGRESSIVE_STANCE_MIN_POWER_MULT = float

        ### How much does weapon preference tags in the ship designer affect the weight it assigns a weapon?
        DESIGNER_WEAPON_PREF_MUL = float
        ### How much does weapon role tags in the ship designer affect the weight it assigns a weapon?
        DESIGNER_WEAPON_ROLE_MUL = float
        ### How much does weapon role tags in the ship designer affect the weight it assigns a utility component
        DESIGNER_UTILITY_ROLE_MUL = float
        ### The higher this is the more the ship designer will try to vary which weapon types are used on its sections
        DESIGNER_WEAPON_STACKING_DIV = float

        ### Abandoned stations lose this amount of health per day
        ABANDONED_STATION_DECAY_RATE = float

        STRIKE_CRAFT_COMBAT_REGEN = float

        MOVE_SHIP_TO_FLEET_MAX_DIST = float

        ### Shields recharge this much faster outside combat
        OUT_OF_COMBAT_SHIELD_REGEN_MULT = float

        ### Armor recharge this much faster outside combat
        OUT_OF_COMBAT_ARMOR_REGEN_MULT = float

        ### Hull recharge this much faster outside combat
        OUT_OF_COMBAT_HULL_REGEN_MULT = float

        ### Setting this to 1 makes the scripted speed value correspond to units/day
        SHIP_SPEED_SCALE = float

        ### The maximum evasion value a ship is allowed to have (percent)
        SHIP_MAX_EVASION = float

        ### The maximum scaling value a target is allowed to have (ship size)
        MAX_DAMAGE_SCALING = int

        ### The orbiting distance of the ship in a process of assisting cloaking detection
        ASSIST_CLOAKING_DETECTION_ORBIT_DISTANCE = float

