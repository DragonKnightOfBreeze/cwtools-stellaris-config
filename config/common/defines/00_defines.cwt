        ### overall military power of PD is increased to compensate for relatively bad DPS/range
        MILITARY_POWER_PD_MULT = float
        ### increase the expected DPS and military power for weapons with size multipliers as if they're fighting this
        MILITARY_POWER_SIZE_MULTIPLIER_WEIGHT = float

        DEFAULT_ARMOR_RATIO = float
        DEFAULT_SHIELD_RATIO = float
