    NAI = {
        ### AI will not build new districts on a planet with more than this many free jobs
        AI_FREE_JOBS_DISTRICT_BUILD_CAP = int
        ### AI will not build new buildings on a planet with more than this many free jobs
        AI_FREE_JOBS_BUILDING_BUILD_CAP = int
        ### AI will score buildings producing resources in deficit this much more
        AI_DEFICIT_SCORE_MULT = int
        ### AI will score buildings producing rare resources this much more
        AI_RARE_RESOURCE_SCORE_MULT = int
        ### AI will score buildings producing focus resources this much more
        AI_FOCUS_SCORE_MULT = int
        ### AI will score resource producing buildings this much more
        AI_RESOURCE_PRODUCTION_SCORE_MULT = int
        ### AI will score amenity buildings this much more than other misc resources
        AI_AMENITIES_SCORE_MULT = int
        ### AI will score housing buildings this much more than other misc resources
        AI_HOUSING_SCORE_MULT = int
        ### AI will score crime fighting buildings this much more than other misc resource
        AI_CRIME_REDUCTION_SCORE_MULT = float
        ### AI will start to think about reducing crime after this threshold has been reached
        AI_CRIME_REDUCTION_THRESHOLD = int
        ### AI will score admin cap buildings this much more than other misc resource
        AI_ADMIN_CAP_SCORE_MULT = int
        ### AI will score pop growth and assembly buildings this much more ( already fairly high weighted in code )
        AI_POPS_SCORE_MULT = float
        ### AI will score naval cap buildings this much more than other misc resource
        AI_NAVAL_CAP_SCORE_MULT = int
        ### AI will consider a job defined as a giving pop growth if it gives at least this many % bonus
        AI_POP_GROWTH_JOB_TRESHOLD = float
        ### AI will score building upgrades this much more ( since they don't take up a new building slot )
        AI_UPGRADE_SCORE_MULT = int
        ### AI will not build starbase modules (or defense platforms) if energy income is below this threshold
        AI_MIN_CURRENCY_INCOME_TO_BUILD_STARBASE_MODULES = int
        ### AI will not build defense platforms if it is using less than this amount of its naval cap
        AI_MIN_NAVAL_CAP_USAGE_TO_BUILD_DEFENSE_PLATFORMS = float
        ### AI will prioritize capturing critters that are not seeded (Fruitful Partnership)
        AI_FRUITFUL_SCORE_MULT = int

        ### AI will try to reduce the amount of amenities on a planet if it's above this number by downprioritizing amenity jobs
        AI_UPPER_AMENITIES_LIMIT = int
        ### AI will try to increase amenities on a planet if it's below this number by increasing priority of amenity jobs
        AI_LOWER_AMENITIES_LIMIT = int

        ### AI will try to build new amenity buildings if below this amenity target
        AI_PLANET_LOWER_THRESHOLD_AMENITY_CONSTRUCTION = int
        ### AI will try to build new amenity buildings if below this amenity target
        AI_PLANET_UPPER_THRESHOLD_AMENITY_CONSTRUCTION = int
        ### AI will try to build new amenity buildings if below this stability target
        AI_PLANET_STABILITY_THRESHOLD_AMENITY_CONSTRUCTION = int

        ### With only one District cap left, the AI will subtract the second best choice times this number from the
        ### weight for building a new District (making it relatively more willing to build e.g. a Building instead)
        AI_DISTRICT_MAX_OPPORTUNITY_COST_FACTOR = float
        ### With each additional District cap left, the above deduction is multiplied by this (making it less important).
        AI_DISTRICT_OPPORTUNITY_COST_FALLOFF = float
        ### Above this number of free District cap, opportunity costs aren't considered at all.
        AI_DISTRICT_MAX_FREE_SLOTS_FOR_OPPORTUNITY_COST = int
        ### When evaluating opportunity costs, the AI hypothesizes a competing District with this weight if none are known.
        AI_DISTRICT_MIN_HYPOTHETICAL_WEIGHT = int

        ### With only one Building slot left, the AI will subtract the second best choice times this number from the
        ### weight for building a new Building (making it relatively more willing to build e.g. a District, or a
        ### Building in a different Zone, instead.)
        AI_BUILDING_MAX_OPPORTUNITY_COST_FACTOR = float
        ### With each additional Building slot left, the above deduction is multiplied by this (making it less important).
        AI_BUILDING_OPPORTUNITY_COST_FALLOFF = float
        ### Above this number of free District cap, opportunity costs aren't considered at all.
        AI_BUILDING_MAX_FREE_SLOTS_FOR_OPPORTUNITY_COST = int
        ### When evaluating opportunity costs, the AI hypothesizes a competing Building with this weight if none are known.
        AI_BUILDING_MIN_HYPOTHETICAL_WEIGHT = int

        ### Factor of when a job is considered an amenities job, e.g. for 2 a job needs to produce twice as much amenities as resources
        ### Rescaled by a factor of 100 due to economic/pop changes in 4.0
        AI_IS_AMENITIES_JOB_FACTOR = float
        ### Pops above this rank will not be subject of automatic job reshuffling to balance amenities
        POP_RANK_LIMIT_FOR_AMENITIES_ADJUSTMENT = int
        ### Jobs need to produce at least this many amenities to be considered for the AI amenity shuffling
        AI_MINIMUM_AMENITY_PER_JOB_LIMIT = int

        ### AI will multiply AI weight of rare techs with this value
        AI_TECHNOLOGY_RARE_WEIGHT_MULT = float
        ### AI will multiply AI weight of infinitely repeatable techs with this value
        AI_TECHNOLOGY_INFINITELY_REPEATABLE_WEIGHT_MULT = float

        ### AI will consider leaving the community ( and wont try to join it either ) if theyre in breach of this many resolutions
        AI_IN_BREACH_THRESHOLD = int

        ### AI considers all systems more distant than this to initially be too far away, but this will be multiplied to increase search range when that happens
        AI_MAX_DISTANCE = int
        ### To help the synth Queen hunt Fallen Empires more efficiently
        AI_SYNTH_QUEEN_MAX_FE_HUNTING_DISTANCE = int

        ### AI pays this much (of base) for gene/robomodding projects
        AI_POP_MODIFICATION_DISCOUNT = float

        ### Target must be at least this many systems away for AI to want to use jump drive
        MIN_DISTANCE_TO_JUMP = int
        ### AI will not want to jump into systems unless enemy is this much weaker than them, relatively
        AI_JUMP_DRIVE_BRAVERY = float

        ### AI will not resettle pops from planets that have less pops than this value
        AI_LEAVE_POPS_WHEN_RESETTLING = int

