        AI_MIN_HOLDING_WORTH_TO_BUILD = float

        ### Chance that AI will try to buy pops on the slave market during the monthly AI update 1.0 = 100% chance
        AI_SLAVE_MARKET_BUY_INTERACTION_CHANCE = float
        ### Chance that AI will try to sell pops on the slave market during the monthly AI update 1.0 = 100% chance
        AI_SLAVE_MARKET_SELL_INTERACTION_CHANCE = float
        ### Upper limit on how many pops AI will put on the market
        AI_SLAVE_MARKET_SELL_LIMIT = int
        ### if we have less ec than this, dont buy slaves
        SLAVE_BUY_EC_THRESHOLD = int
        ### if any one planet has this many unemployed pops, don't consider buying slaves for it
        SLAVE_BUY_UNEMPLOYMENT_THRESHOLD = int
        ### if we cant find a planet with at least this much habitability for a prospective slave, dont buy it
        SLAVE_BUY_HABITABILITY_THRESHOLD = float

        ### if we have more ec than this and a positive net income, then don't sell any slaves
        SLAVE_SELL_EC_THRESHOLD = int
        ### if any one planet has this many unemployed pops on it, consider selling one as a slave
        SLAVE_SELL_UNEMPLOYMENT_THRESHOLD = int
        ### do not sell slaves from this planet if it has this amount of pops, or less
        SLAVE_SELL_MIN_POPS = int

        ### When hiring for a job category, how much the score has to be higher than the previous tenants's score to replace him
        SCIENTIST_HIRING_REPLACEMENT_THRESHOLD = float
        ### When hiring a scientist, how much the better score for the new category has to be compared to your current employment score
        SCIENTIST_HIRING_PREV_JOB_THRESHOLD = float
        ### how much of a bonus unemployed scientist get to their job score
        SCIENTIST_HIRING_UNEMPLOYMENT_MULT = float
        ### when hiring for research, the multiplier applied to a scientist who's on a science ship, to ensure surveying has priority over research
        SCIENTIST_HIRING_SURVEY_MULTIPLIER = float

        ### AI multiplier to incentivize surveying systems with known colonizeable planets
        SURVEY_COLONIZABLE_SYSTEM_MULTIPLIER = int

        ### How far away (in jumps) another empire has to be before the empire will not consider them for declaration
        WAR_DECLARATION_MAX_DISTANCE = int
        ### Distance between empires (in jumps) at which the AI will be less likely to declare war
        WAR_DECLARATION_MALUS_DISTANCE = int
        ### malus per jump above the malus distance (above) for each jump
        WAR_DECLARATION_MALUS = float
        ### minimum score multiplier for war declaration after all distance have been applied
        WAR_DECLARATION_MINIMUM_SCORE = float

        ### Number of days automation will not be done after a build queue item on a planet completes
        COLONY_AUTOMATION_COOLDOWN = int
        ### Prefer to build districts over buildings unless there are multiple building slots open or this many times as many districts as buildings, minimum 1
        COLONY_AUTOMATION_DISTRICT_PREFERENCE = int

        ### number of days before the ai will try to repeat a proposal
        DIPLO_ACTION_REPEAT_DELAY = int
        ### number of days cooldown before an AI federation member will suggest changing a law of the same category
        AI_FEDERATION_PROPOSE_LAW_CATEGORY_COOLDOWN = int

        ### the AI weight required to propose a resolution
        RESOLUTION_VOTE_PROPOSE_THRESHOLD = float
        ### the AI weight of a resolution need to be at least this much, else the AI will oppose it
        RESOLUTION_VOTE_ABSTAIN_THRESHOLD = float
        ### if the AI weight of a resolution reaches this value the AI will vote for it
        RESOLUTION_VOTE_SUPPORT_THRESHOLD = float
        ### if the AI hates something this much ( weight is lower ), they might veto it
        RESOLUTION_VOTE_VETO_THRESHOLD = float
        ### if it isnt their own resolution but the AI still loves something this much they might declare it an Emergency Measure
        RESOLUTION_VOTE_EMERGENCY_THRESHOLD = float
        ### if the resolution next in line after the current resolution is this much better, the AI will freeze the current resolution
        RESOLUTION_VOTE_FREEZE_THRESHOLD_DELTA = float
        ### if weight reaches the threshold +/- DELTA (support/abstain) AI will use favors to boost their diplo weight
        RESOLUTION_USE_FAVORS_THRESHOLD_DELTA = float

        # Resolution AI weight is multiplied by values in these ranges based on opinion

        ### Corresponds to Terrible opinion towards the resolution target if resolution is non-harmful, Excellent opinion if harmful
        RESOLUTION_TARGET_OPINION_MIN_FACTOR = float
        ### Will be used if opinion towards resolution target is neutral
        RESOLUTION_TARGET_OPINION_BASE_FACTOR = float
        ### Corresponds to Excellent opinion towards the resolution target if resolution is non-harmful, Terrible opinion if harmful
        RESOLUTION_TARGET_OPINION_MAX_FACTOR = float
        ### Corresponds to Terrible opinion towards the proposer
        RESOLUTION_PROPOSER_OPINION_MIN_FACTOR = float
        ### Will be used if opinion towards the proposer is neutral
        RESOLUTION_PROPOSER_OPINION_BASE_FACTOR = float
        ### Corresponds to Excellent opinion towards the proposer
        RESOLUTION_PROPOSER_OPINION_MAX_FACTOR = float

        ### if we are supporting the resolution, don't spend favors if support percentage is above this
        MAX_SUPPORT_PERCENTAGE_FOR_FAVORS_SUPPORTING = int
        ### if we are opposing the resolution, don't spend favors if support percentage is below this
        MIN_SUPPORT_PERCENTAGE_FOR_FAVORS_OPPOSING = int

        ### AI acceptance boost per favor
        DIPLO_ACTION_FAVOR_AI_ACCEPTANCE_VALUE = int

        AGREEMENT_INFLUENCED_BY_FAVORS_AI_BREAK_COOLDOWN = int

        ### How far out does the Horde AI looks for invasion targets (in system hops)
        HORDE_INVASION_PLANNING_DEPTH = int

        ### How much AI is willing to pay for planetary ascension in relation to the cost of a tradition
        PLANETARY_ASCENSION_ALLOWED_SPENDING = float

        ### How far out does the Swarm AI looks for invasion targets (in system hops)
        SWARM_INVASION_PLANNING_DEPTH = int
        ### Extra target scoring for swarm (multiplied by number of edible pop on the planet)
        SWARM_POP_TARGET_MULT = float
        ### Extra target scoring for swarm (multiplied by number of non edible pop on the planet)
        SWARM_UNEDIBLE_POP_TARGET_MULT = float
        SWARM_NUM_DEFENSIVE_FLEETS = int
        ### Extra incentive to keep taking a partially conquered system. Mostly relevant for multi-planet systems with no starbase (already destroyed).
        SWARM_FULLY_CONQUER_SYSTEM = int

        ### how much the contingency wants to link up its various hubs
        CONTINGENCY_LINKUP_DESIRE = int
        ### How attractive are megastructures to the Contingency (added to the base value of 1)
        CONTINGENCY_MEGASTRUCTURE_EXTRA_VALUE = int
        ### Number of active hubs is added to this
        CONTINGENCY_BASE_DEFENSIVE_FLEETS = int
        ### Number of systems not owned by the contingency construction fleet are willing to go through
        CONTINGENCY_CONSTRUCTION_DEPTH = int

        ### How much does the Unbidden want to defend their portal (compared to base value of 1)
        UNBIDDEN_PORTAL_EXTRA_VALUE = int
        ### How attractive are bypasses to the Unbidden (added to the base value of 1)
        UNBIDDEN_BYPASSES_EXTRA_VALUE = int
        ### How attractive are astral rifts to the Unbidden (added to the base value of 1)
        UNBIDDEN_ASTRAL_RIFTS_EXTRA_VALUE = int
        ### Extra target scoring for rival invaders (Aberrant and Vehement)
        UNBIDDEN_RIVALS_EXTRA_VALUE = int
        ### Extra target scoring for randomly chosen nemesis
        UNBIDDEN_TARGET_EXTRA_VALUE = int

        ### Ballpark estimate of the minimum size a fleet should be in relation to total fleet power
        AVERAGE_FLEET_SIZE_FACTOR = int
        ### Maximum number of hops the fleet AI should consider when assigning mission.
        FLEET_MAX_DISTANCE_LOOKUP = int

        ### Maximum number of hops the fleet AI should consider when assigning mission on a large map (800 systems or more).
        FLEET_MAX_DISTANCE_LOOKUP_LARGE = int
        ### Maximum number of hops the fleet AI should consider when assigning mission on a large map (1000 systems or more)
        FLEET_MAX_DISTANCE_LOOKUP_HUGE = int

        ### Score penalty for the distance (number of jumps) for AI construction of mining stations etc
        CONSTRUCTION_SHIP_DISTANCE_PENALTY = int

        ### How much does AI count its own fleet power when evaluating forces
        OWN_FLEET_POWER_FACTOR = float
        ### How much does AI count ally fleet power when evaluating forces
        ALLY_FLEET_POWER_FACTOR = float
        ### How much does AI count enemy fleet power when evaluating forces
        ENEMY_FLEET_POWER_FACTOR = float
        ### How stronger should the AI be before it starts considering splitting fleets (fleet count = relative strength / this factor)
        FLEET_SUPERIORITY_FACTOR = float
        ### Same as previous but will be compared to the strongest foe in the universe
        CRISIS_FLEET_SUPERIORITY_FACTOR = float

        ### extra incentive for crisis to destroy inhibitors, currently only used by the extra dimensionals
        CRISIS_INHIBITOR_EXTRA_VALUE = int

        ### AI desire to follow "take point" fleets from random people
        AI_FOLLOW_FLEET_DESIRE = int
        ### AI desire to follow "take point" fleets from the war leader
        AI_FOLLOW_WAR_LEADER_DESIRE = int

        ### Used when calculating atitude protective weigth
        CRISIS_EMPIRE_PROTECTIVE_MULT = float
        ### The time that the Galactic Defense Force AI will stay in orbit around a capital before moving to the next one
        AI_GALCOM_PATROL_ORBIT_TIME_DAYS = int

        ### AI desire to destroy stars as a crisis empire
        CRISIS_EMPIRE_DESTROY_DESIRE = int

        ### AI will redesign its per-role custom designs this often (from scratch;
        ### new tech will upgrade individual components more often however)
        SHIP_DESIGN_STALE_MONTHS = int

        ### AI scripted weight threshold to propose the embassy diplomatic action
        PROPOSE_EMBASSY_THRESHOLD = int

        ### How much more a ship or defense platform need to increase their fleet power for AI to start upgrading it
        SHIP_FLEET_POWER_UPGRADE_THRESHOLD = float
        ### Bonus to resources gained from designations that align with economic plan, resources we have a surplus of gets divided by this factor
        AI_DESIGNATION_RESOURCES_IN_ECONOMIC_PLAN_BONUS = float
        ### Number of days that AI has to wait before changing designation again
        AI_DESIGNATION_COOLDOWN = int

        ### Default amount of days a fleet can be rented for
        MERCENARY_ENCLAVE_OFFER_FLEET_RENT_DAYS = int
        ### Default amount of days a fleet contract can be extended for
        MERCENARY_ENCLAVE_OFFER_FLEET_CONTRACT_PROLONGATION_DAYS = int
        ### A country should have on the deposit more than the price of fleet hiring multiplied by this value to be able to hire the fleet
        MERCENARY_ENCLAVE_OFFER_FLEET_CAN_AFFORD_FACTOR = float
        ### The fleet power multiplied by this value defines one of the components of how appealing is the hiring of this fleet
        MERCENARY_ENCLAVE_OFFER_FLEET_POWER_SCORE_FACTOR = float
        ### The fleet hiring cost multiplied by this value defines one of the components of how appealing is the hiring of this fleet
        MERCENARY_ENCLAVE_OFFER_FLEET_COST_SCORE_FACTOR = float
        ### The amount of FTL jumps the fleet needs to reach the capital star system of a country multiplied by this value defines one of the components of how appealing is the hiring of this fleet
        MERCENARY_ENCLAVE_OFFER_FLEET_REMOTENESS_SCORE_FACTOR = float
        ### The fleet hiring cost multiplied by this value defines one of the components of how appealing is the hiring of this fleet
        MERCENARY_ENCLAVE_OFFER_FLEET_REMOTENESS_MAX = int
        ### If a random number is less than this value the most appealing fleet will be hired by a country in the normal state
        MERCENARY_ENCLAVE_OFFER_FLEET_AI_CHANCE_TRHESHOLD = int
        ### If a random number is less than this value the most appealing fleet will be hired by a country in the state of war
        MERCENARY_ENCLAVE_OFFER_FLEET_AI_CHANCE_INWAR_ADD = int
        ### If a random number is less than this value the most appealing fleet will be hired by a country in the state of preparing to war
        MERCENARY_ENCLAVE_OFFER_FLEET_AI_CHANCE_PREPARING_WAR_ADD = int
        ### The fleet power multiplied by this value defines the price (in energy) for hiring the fleet
        MERCENARY_ENCLAVE_OFFER_FLEET_POWER_TO_PRICE_FACTOR = float
        ### Hiring a fleet: this value defines the maximal decrease of the price
        MERCENARY_ENCLAVE_OFFER_FLEET_TRUST_PRICE_FACTOR = float
        ### Hiring a fleet: if the merc enclave has opinion of a country that is less than this value the offer is not given
        MERCENARY_ENCLAVE_OFFER_FLEET_TRUST_THRESHOLD = int
        ### Hiring a fleet: this value defines the maximal decrease of the price (if the founder of the merc enclave has the most positive opinion of a country) or the maximal increase of the price (if the founder of the merc enclave has the most negative opinion of a country)
        MERCENARY_ENCLAVE_OFFER_FLEET_LANDLORD_OPINION_PRICE_FACTOR = float
        ### NGameplay::OPINION_POOR: if the opinion of the enclave landlord towards the potential buyer is less than this value the offer vill be not given
        MERCENARY_ENCLAVE_OFFER_FLEET_LANDLORD_OPINION_THRESHOLD = int
        ### The fleet power multiplied by this value defines the price (in energy) for extension of the fleet contract
        MERCENARY_ENCLAVE_OFFER_FLEET_CONTRACT_PROLONGATION_POWER_TO_PRICE_FACTOR = float
        ### Extension of a fleet contract: this value defines the maximal decrease of the price (if the merc enclave has the most positive opinion of a country) or the maximal increase of the price (if the merc enclave has the most negative opinion of a country)
        MERCENARY_ENCLAVE_OFFER_FLEET_CONTRACT_PROLONGATION_TRUST_PRICE_FACTOR = float
        ### Extension of a fleet contract: if the merc enclave has opinion of a country that is less than this value the offer is not given
        MERCENARY_ENCLAVE_OFFER_FLEET_CONTRACT_PROLONGATION_TRUST_THRESHOLD = int
        ### Extension of a fleet contract: this value defines the maximal decrease of the price (if the founder of the merc enclave has the most positive opinion of a country) or the maximal increase of the price (if the founder of the merc enclave has the most negative opinion of a country)
        MERCENARY_ENCLAVE_OFFER_FLEET_CONTRACT_PROLONGATION_LANDLORD_OPINION_PRICE_FACTOR = float
        ### NGameplay::OPINION_POOR # Extension of a fleet contract:if the opinion of the enclave landlord towards the potential buyer is less than this value the offer vill be not given
        MERCENARY_ENCLAVE_OFFER_FLEET_CONTRACT_PROLONGATION_LANDLORD_OPINION_THRESHOLD = int
        ### If a random number is less than this value and there is an appropriate fleet in an appropriate star system then the merc enclave will be created
        MERCENARY_ENCLAVE_ESTABLISHING_AI_CHANCE_THRESHOLD = int

        ### Acceptance from loyalty = OFFSET+FACTOR*e^(LOYALTY*EXP)
        ASK_FOR_AGREEMENT_ACCEPTANCE_OVERLORD_LOYALTY_OFFSET = int
        ASK_FOR_AGREEMENT_ACCEPTANCE_OVERLORD_LOYALTY_FACTOR = int
        ASK_FOR_AGREEMENT_ACCEPTANCE_OVERLORD_LOYALTY_EXP = float
        NEGOTIATE_AGREEMENT_ACCEPTANCE_SUBJECT_POWER_STEP = int
        DEMAND_SUBJUGATION_ACCEPTANCE_SUBJECT_POWER_STEP = int
        NEGOTIATE_AGREEMENT_ACCEPTANCE_OPINION_FACTOR = float
        NEGOTIATE_AGREEMENT_MIN_ECONOMY_WEIGHT = float
        ### Pretty much only Energy. Tithes are assumed to be on at least this much income.
        NEGOTIATE_AGREEMENT_MIN_REFERENCE_RESOURCE = float
        ### E.g science. Tithes are assumed to be on at least this much income.
        NEGOTIATE_AGREEMENT_MIN_REFERENCE_INTANGIBLE = float
        ### Very approximately, this corresponds to giving away the entire economy
        NEGOTIATE_AGREEMENT_ACCEPTANCE_ECONOMIC_IMPACT_MULTIPLIER = float
        NEGOTIATE_AGREEMENT_ACCEPTANCE_INTANGIBLE_IMPACT_MULTIPLIER = float
        NEGOTIATE_AGREEMENT_MAX_ACCEPTANCE_FROM_TERMS = int
        NEGOTIATE_AGREEMENT_MIN_ACCEPTANCE_FROM_TERMS = int

        # Loyalty is multiplied by this and added to (overlord's) acceptance

        NEGOTIATE_AGREEMENT_ACCEPTANCE_LOYALTY_RELATIVE_POWER_PATHETIC = float
        NEGOTIATE_AGREEMENT_ACCEPTANCE_LOYALTY_RELATIVE_POWER_INFERIOR = int
        NEGOTIATE_AGREEMENT_ACCEPTANCE_LOYALTY_RELATIVE_POWER_EQUIVALENT = int
        NEGOTIATE_AGREEMENT_ACCEPTANCE_LOYALTY_RELATIVE_POWER_SUPERIOR = int
        NEGOTIATE_AGREEMENT_ACCEPTANCE_LOYALTY_RELATIVE_POWER_OVERWHELMING = int

        ### If subject is/will be a Specialist, Loyalty is multiplied by this and added to (overlord's) acceptance
        NEGOTIATE_AGREEMENT_ACCEPTANCE_LOYALTY_SPECIALIST = int

        SPECIMEN_TRADE = value[country_flag]
        SPECIMEN_TRADE_FLAG_DAYS = int

        ### Multiplied with the disloyalty of a subject. If this is higher, the AI subject is more likely to pledge Secret Fealty
        SECRET_FEALTY_PLEDGE_TERMS_MULTIPLIER = int
        ### A higher value makes the AI subject more likely to pledge a Secret Fealty to another empire
        SECRET_FEALTY_PLEDGE_TERMS_BONUS = int
        ### # Multiplied with the disloyalty of a subject. If this is higher, the AI is more likely to propose a subject to pledge Secret Fealty
        SECRET_FEALTY_PROPOSE_TERMS_MULTIPLIER = int
        ### A higher value makes the AI subject more likely to propose for a subject empire to pledge a Secret Fealty to them
        SECRET_FEALTY_PROPOSE_TERMS_BONUS = int

        ### Multiplied with the loyalty of a subject. If this is higher, the AI subject is more likely to break Secret Fealty
        SECRET_FEALTY_BREAK_TERMS_MULTIPLIER = int
        ### A higher value makes the AI subject more likely to break a Secret Fealty to another empire
        SECRET_FEALTY_BREAK_TERMS_BONUS = int
        ### Subject will break the pledge when loyalty reaches this value.
        SECRET_FEALTY_BREAK_LOYALTY_THRESHOLD = int
        ### Subject will break the pledge when potential overlords relative power to current overlord is lower than this value.
        SECRET_FEALTY_BREAK_RELATIVE_POWER_THRESHOLD = float

        ### How much does the Formless want to defend their anchor (compared to base value of 1)
        FORMLESS_ANCHOR_EXTRA_VALUE = int

        ### How important is the distance from a bypass to the capital
        DIMENSIONAL_LOCK_AI_WEIGHT_DISTANCE_TO_CAPITAL_MAX_WEIGHT = int
        ### How important is a bypass linking to a system which owner is a rival
        DIMENSIONAL_LOCK_AI_WEIGHT_RIVALRY = int
        ### How important is a bypass linking to a system which owner is at war
        DIMENSIONAL_LOCK_AI_WEIGHT_WAR = int
        ### How important is a bypass linking to a system which owner is an ally
        DIMENSIONAL_LOCK_AI_WEIGHT_ALLIANCE = int
        ### How important is a bypass linking to a system with closed borders
        DIMENSIONAL_LOCK_AI_WEIGHT_CLOSED_BORDERS = int
        ### How important is a bypass linking to a system with no owner
        DIMENSIONAL_LOCK_AI_WEIGHT_NO_OWNER = int

        ### Flags that indicate what cosmic storm an AI country in affected by
        AFFECTED_BY_SHROUD_STORM_FLAG = value[country_flag]
        AFFECTED_BY_GRAVITY_STORM_FLAG = value[country_flag]
        AFFECTED_BY_SOLAR_STORM_FLAG = value[country_flag]

        ### the multiplier is applied to number of pops
        LOCATION_WEIGHT_PLANET_MULTIPLIER = float
        ### the multiplier is applied to number of ships in the fleet
        LOCATION_WEIGHT_FLEET_MULTIPLIER = float
        ### the multiplier is applied to the number of members in the federation
        LOCATION_WEIGHT_FEDERATION_MULTIPLIER = float

        ### Weight for the galactic community when it is formed, this is not a multiplier but a flat value
        LOCATION_WEIGHT_GALACTIC_COMMUNITY = float

        ### Shipsize of ships created from bombardments
        VOIDWORMS_NEWBORNS_SHIP_SIZE = <ship_size>
        ### Shipsize of the ships exploring the galaxy
        VOIDWORMS_EXPLORER_SHIP_SIZE = <ship_size>
        ### Shipsize of the ships waiting to be merged into aggressive fleets
        VOIDWORMS_ADULTS_SHIP_SIZE = <ship_size>
        ### Shipsize of the ships attacking and bombarding players
        VOIDWORMS_AGRESSIVE_SHIP_SIZE = <ship_size>
        ### Voidworms home system flag (can be multiple systems)
        VOIDWORMS_HOME_SYSTEM_FLAG = value[star_flag]
        ### Voidworms starbase flag
        VOIDWORMS_STARBASE = value[ship_flag]
        ### Voidworms fleet new when they split
        VOIDWORMS_NEW_FLEET_NAME = localisation
        ### Minimum pops on a planet to be targeted for bombardments
        VOIDWORMS_MINIMUM_POPS_TO_TARGET = int
        ### Maximum of pops a voidworm fleet may kill in a single attack
        VOIDWORMS_MAXIMUM_POPS_TO_KILL = int
        ### Maximum of pops a voidworm fleet may kill in a single attack (Civilian difficulty)
        VOIDWORMS_MAXIMUM_POPS_TO_KILL_CIVILIAN = int
        ### Limit of used naval capacity allowed per voidworm fleet
        VOIDWORMS_NAVAL_CAP_PER_FLEET = single_alias_right[int_array]
        ### Variables holding a voidworm fleet kill count in the current attack
        VOIDWORM_KILLED_POPULATION_COUNT = value[variable]
        ### How long a country cannot be targeted by a voidworm attack after having being targeted
        VOIDWORM_ATTACK_AGAINST_PLAYER_COOLDOWN_DAYS = int
        ### Flag used to prevent voidworms attack
        VOIDWORM_RECENTLY_TARGETED_FLAG = value[country_flag]
        ### Threshold (%) to go explore the galaxy from the home system
        VOIDWORM_EXPLORING_FACTOR = int
        ### Threshold (%) to wander among the different planets of the hom system
        VOIDWORM_WANDERING_FACTOR = int
        ### Maximum jumps from home system to picked system to explore
        VOIDWORM_EXPLORATION_MAX_JUMPS = int
        ### Flag to communicate to the ai to use the crisis behaviour
        VOIDWORM_CRISIS_ACTIVE = value[country_flag]
        ### How many ships maximum is there in a single aggressive fleet
        VOIDWORM_AGGRESSIVE_FLEETS_MAX_SHIPS = int
        ### How many ships maximum is there in a single aggressive fleet during the crisis
        VOIDWORM_CRISIS_AGGRESSIVE_FLEETS_MAX_SHIPS = int
        ### Country flag to make countries immune to voidworm attacks
        VOIDWORM_BOMBARDMENT_IMMUNITY_FLAG = value[country_flag]
        ### Country flag to check if Voidworm fleet is actively bombarding a planet
        VOIDWORM_ACTIVELY_BOMBARDING_FLAG = value[fleet_flag]

        ### How many mutations of each type the AI attempts to apply ( Offensive, Defensive, Auxiliary )
        CREATURE_DESIGNER_MUTATION_TYPE_PREFERENCES = single_alias_right[int_array]

        ### the AI will build the deep space citadel at this percentage of the inner radius of a system
        DEEPSPACE_CITADEL_INNER_RADIUS_PERCENTAGE = float
    }
}
