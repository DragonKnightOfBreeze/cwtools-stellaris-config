        # Above are various acceptance factors for specific actions

        ### These variables are used for some of the AI's budgeting to ensure it prioritizes the right things early on
        AI_BUDGETING_START_YEARS = int
        AI_BUDGETING_MID_YEARS = int
        AI_BUDGETING_LATE_YEARS = int

        ### At AI weight less than or equal to this, demolish building or district
        BUILDING_DEMOLISH_THRESHOLD = int
        ### Ait AI weight greater than or equal to this, the AI will consider building it.
        BUILDING_BUILD_THRESHOLD = int

        MIN_ASSAULT_ARMIES = int
        MAX_ASSAULT_ARMIES = int
        ASSAULT_ARMIES_PER_POP = float

        ### The higher this is, the more the AI will avoid building the same building on planets
        BUILDING_EXISTS_DIV_SCORE = int

        ### How many traditions does the AI want before spending Unity on edicts (there are 49 in total in the base game counting adoption & completion effects)
        NUM_TRADITIONS_FOR_EDICTS = int

        ### At this amount of planets budget is normalized
        MAX_PLANETS_FOR_BUDGET_FACTOR = int

        ### Planets are considered underdeveloped if they have fewer than this many pops
        UNDERDEVELOPED_POP_LIMIT = int
        ### The AI prefers not to have more than this many underdeveloped colonies
        UNDERDEVELOPED_PLANET_LIMIT = int
        ### Below this planet count the AI gets a colonization weight boost to prioritize early expansion
        AI_FEW_PLANETS_COLONIZATION_THRESHOLD = int
        ### Per missing planet below the threshold, multiplied into colonization weight (e.g. 0.25 with 2 planets below threshold = +75% colonization weight)
        AI_FEW_PLANETS_COLONIZATION_BOOST = float
        ### Planet needs this many sapient pops before the AI gets a boost toward building one of every eligible district type
        AI_UNBUILT_DISTRICT_BOOST_POP_THRESHOLD = int
        ### Weight multiplier applied to a district type the planet can build but has zero of (built or queued), only when at least one of its zone slots has an unlocked zone
        AI_UNBUILT_DISTRICT_BOOST_MULTIPLIER = float
        ### Candidate zone's designation affinity must exceed the existing zone's by at least this amount before the AI will consider swapping them.
        AI_ZONE_SPECIALIZATION_AFFINITY_DELTA = float
        ### Each existing building in the slot that the candidate zone cannot host (its building sets don't match) subtracts this much from the candidate's effective designation affinity when deciding whether to swap.
        AI_ZONE_SWAP_BUILDING_LOSS_PENALTY = float
        ### Minimum CalcBuildWeight a zone-swap proposal must reach before the AI will queue it.
        AI_ZONE_SWAP_MIN_BUILD_WEIGHT = float
        ### Multiplier applied to AI_ZONE_SPECIALIZATION_AFFINITY_DELTA when the slot is already occupied by a specialized zone (affinity > 1.0).
        AI_ZONE_SWAP_RATCHET_MULT = float
        ### Per tangible resource currently near its stockpile cap
        AI_STORAGE_BUILDING_CAPPED_RESOURCE_BOOST = int

        ### AI wants a navy of at least this fleetsize before buying an admiral
        MIN_NAVY_SIZE_FOR_ADMIRAL = int
        ### AI will refit its fleet to fit into the admirals specialization if at least this ratio of ships will be upgraded
        FLEET_SPECIALIZATION_REFIT_TRESHOLD = float

        ### MilitaryPower fraction below this level will result in AI escaping battle
        ABORT_MISSION_LIMIT = float

        ### AI may want to intervene to help empires with this war exhaustion or higher
        WAR_EXHAUSTION_TO_INTERVENE = float

