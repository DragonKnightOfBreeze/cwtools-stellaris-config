        FLEET_BASE_FORMATION_DIV = int

        FLEET_FORMATION_CIRCLE_SHIPS_PER_LAYER_MULT = int
        FLEET_FORMATION_CIRCLE_RADIUS_PER_LAYER_MULT = float

        ### Scale the importness of the number of items in the construction queue when calculating best shipyard for upgrade in.
        FLEET_UPGRADE_QUEUE_FACTOR_MULT = float

        ### Amount of days it takes to land an army
        LANDING_TIME_DAYS = int

        ### distance threshold used by move_to fleet action to determine when the fleet arrived
        MOVE_TO_ACTION_THRESHOLD = float

        ### In micro updates ( 10/day )
        HYPERLANE_WINDUP = int
        ### In micro updates
        HYPERLANE_WINDDOWN = int
        ### In micro updates ( 10/day )
        HYPERDRIVE_INTERSTELLAR_TRAVEL_SPEED = float
        ### Scale up of unique ruler ship.
        RULER_SHIP_SCALE_MULT = float
        ### Jump drive windup in days
        JUMP_DRIVE_WINDUP = int
        JUMP_DRIVE_RANGE = int
        ### Bigger the value faster the windup time will be.
        QC_WINDUP_SHIP_SIZE_DIV = int
        ### Ship size after which the windup mult will be applied.
        QC_WINDUP_SHIP_SIZE = int

        ### Combat ticks before a shield that is fully depleted will start to recharge
        SHIELD_RECHARGE_TICKS = int

        MILITARY_POWER_HEALTH_WEIGHT = float
        ### compared to health
        MILITARY_POWER_ARMOR_WEIGHT = float
        ### compared to health
        MILITARY_POWER_SHIELD_WEIGHT = float
        MILITARY_POWER_DAMAGE_WEIGHT = float
        MILITARY_POWER_SCALE = float
        ### math: power = ( ( effective_health * damage_per_day ) ^ exponent ) * scale
        MILITARY_POWER_EXPONENT = float

        ### larger value = adds more military power
        MILITARY_POWER_ARMOR_PENETRATION_WEIGHT = float
        MILITARY_POWER_SHIELD_PENETRATION_WEIGHT = float
